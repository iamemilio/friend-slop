[resource]
script = ExtResource("1")
tree_id = "warden"
display_name = "Warden"
starting_node_ids = Array[String](["hunter", "deceiver", "architect"])
node_labels = {
"architect": "Architect",
"deceiver": "Deceiver",
"hunter": "Hunter"
}
starting_node_spells = {
"architect": ["warden_shift", "warden_seal", "warden_forge"],
"deceiver": ["warden_whisper", "warden_mirror", "warden_fade"],
"hunter": ["warden_stalk", "warden_pounce", "warden_mark"]
}
nodes = Array[ExtResource("2_node")]([SubResource("node_hunter"), SubResource("node_deceiver"), SubResource("node_architect"), SubResource("node_predator"), SubResource("node_echo"), SubResource("node_bulwark"), SubResource("node_bloodscent"), SubResource("node_phantom"), SubResource("node_overseer")])
