; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="FriendSlop"
run/main_scene="res://scenes/menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

driver/enable_input=true

[autoload]

GameState="*res://scripts/game_state.gd"
SettingsManager="*res://scripts/settings_manager.gd"
TomeDebug="*res://scripts/debug/tome_debug.gd"
SpeechSttLoader="*res://scripts/spells/speech_stt_loader.gd"
TrailRegistry="*res://scripts/trails/trail_registry.gd"
SteamService="*res://scripts/network/steam_service.gd"
NetworkManager="*res://scripts/network/network_manager.gd"
MatchStateManager="*res://scripts/match/match_state_manager.gd"
FriendSlopVoiceAdapter="*res://scripts/voice/friend_slop_voice_adapter.gd"

[editor_plugins]

enabled=PackedStringArray()

