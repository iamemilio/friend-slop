{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup (make)",
      "type": "shell",
      "command": "make setup",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run All Checks",
      "type": "shell",
      "command": "python \"${workspaceFolder}/tools/run_checks.py\"",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "GDScript: Lint",
      "type": "shell",
      "command": "python \"${workspaceFolder}/tools/run_checks.py\" --lint-only",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "GDScript: Analyzer Warnings",
      "type": "shell",
      "command": "python \"${workspaceFolder}/tools/run_checks.py\" --warnings-only --require-godot-warnings",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Godot: Run Unit Tests",
      "type": "shell",
      "command": "make test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
